# ============================================
# ML Workflow 环境变量配置模板
# 复制此文件为 .env 并填入你的真实配置
# ============================================
# 注意：.env 文件包含敏感信息（API Key），切勿提交到 Git！


# ============================================
# 1. 全局 LLM 配置（默认模型，用于对话和通用任务）
# ============================================

# 提供商：openai / ollama / anthropic 等
LLM_PROVIDER=openai

# API 基础地址（OpenAI 兼容格式）
# 硅基流动: https://api.siliconflow.cn/v1
# DeepSeek: https://api.deepseek.com/v1
# 阿里云百炼: https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_BASE_URL=https://api.siliconflow.cn/v1

# 【必填】你的 API Key
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 模型名称
# 硅基流动示例: Qwen/Qwen3-Coder-30B-A3B-Instruct, deepseek-ai/DeepSeek-V3
# DeepSeek 示例: deepseek-chat, deepseek-coder
LLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# 采样温度（0~1，越小越稳定）
LLM_TEMPERATURE=0.3

# 最大生成 token 数
LLM_MAX_TOKENS=4096


# ============================================
# 2. 评测系统 - PlanCoding Agent（代码生成）
# ============================================
# 这是核心代码生成 Agent，建议使用最强模型

EVAL_PLAN_CODING_PROVIDER=openai
EVAL_PLAN_CODING_BASE_URL=https://api.siliconflow.cn/v1
EVAL_PLAN_CODING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EVAL_PLAN_CODING_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
EVAL_PLAN_CODING_TEMPERATURE=0.2
EVAL_PLAN_CODING_MAX_TOKENS=4096
# JSON 格式额外参数（如 enable_thinking），不需要则留空
EVAL_PLAN_CODING_EXTRA_BODY=


# ============================================
# 3. 评测系统 - Judge Agent（评估判断）
# ============================================
# 评估模型质量和通过/拒绝判断，可本地部署节省成本

EVAL_JUDGE_PROVIDER=ollama
EVAL_JUDGE_BASE_URL=http://localhost:11434/v1
# Ollama 不需要真实 API Key，但不能为空
EVAL_JUDGE_API_KEY=ollama
EVAL_JUDGE_MODEL=qwen2.5:14b
EVAL_JUDGE_TEMPERATURE=0.1
EVAL_JUDGE_MAX_TOKENS=2048
EVAL_JUDGE_EXTRA_BODY=


# ============================================
# 4. 评测系统 - Intent Recognition Agent（意图识别）
# ============================================
# 识别目标列、任务类型、评估指标，任务简单，小模型即可

EVAL_INTENT_PROVIDER=ollama
EVAL_INTENT_BASE_URL=http://localhost:11434/v1
EVAL_INTENT_API_KEY=ollama
EVAL_INTENT_MODEL=qwen2.5:7b
EVAL_INTENT_TEMPERATURE=0.2
EVAL_INTENT_MAX_TOKENS=1024
EVAL_INTENT_EXTRA_BODY=


# ============================================
# 5. 应用基础配置（可选，保持默认即可）
# ============================================

# APP_NAME=ML Agent Backend
# DEBUG=false


# ============================================
# 6. 沙箱执行配置（可选）
# ============================================

# 代码执行超时时间（秒）
# SANDBOX_TIMEOUT=300

# 内存限制
# SANDBOX_MEMORY_LIMIT=2g

# CPU 核心数限制
# SANDBOX_CPU_LIMIT=2.0


# ============================================
# 7. 快速模式限制（可选）
# ============================================

# 最大优化轮数
# FAST_MAX_OPTIMIZE_ROUNDS=3

# 最大调试轮数
# FAST_MAX_DEBUG_ROUNDS=5


# ============================================
# 8. 数据切分默认配置（可选）
# ============================================

# 验证集比例
# DEFAULT_TEST_SIZE=0.2

# 随机种子
# DEFAULT_RANDOM_STATE=42
