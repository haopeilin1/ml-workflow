# ============================================
# ML Workflow 环境变量配置文件
# Plan/Coding 分离后的 LLM 配置指南
# ============================================


# ============================================
# 1. 全局 LLM 配置（所有 Agent 的兜底配置）
# ============================================

LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your-api-key
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096


# ============================================
# 2. 代码生成 Agent 配置（Plan + Coding + Simple 的共同回退）
# ============================================
# 如果你只想配一个模型给所有代码生成任务用，配这里就够了。
# Plan/Coding/Simple 如果没单独配置，会自动回退到这里。

EVAL_PLAN_CODING_PROVIDER=openai
EVAL_PLAN_CODING_BASE_URL=http://localhost:8000/v1
EVAL_PLAN_CODING_API_KEY=not-needed
EVAL_PLAN_CODING_MODEL=qwen3.6-27b
EVAL_PLAN_CODING_TEMPERATURE=0.2
EVAL_PLAN_CODING_MAX_TOKENS=4096
EVAL_PLAN_CODING_EXTRA_BODY=


# ============================================
# 3. 【新增】Plan Agent 专用配置（复杂任务第一步：生成结构化计划）
# ============================================
# 计划生成主要是分析 + 规划，不需要代码能力特别强，可以用轻量级模型。
# 如果不配置，自动回退到 EVAL_PLAN_CODING_* → LLM_*

# EVAL_PLAN_PROVIDER=openai
# EVAL_PLAN_BASE_URL=http://localhost:8000/v1
# EVAL_PLAN_API_KEY=not-needed
# EVAL_PLAN_MODEL=qwen2.5-14b
# EVAL_PLAN_TEMPERATURE=0.3
# EVAL_PLAN_MAX_TOKENS=4096
# EVAL_PLAN_EXTRA_BODY=


# ============================================
# 4. 【新增】Coding Agent 专用配置（复杂任务第二步：写代码）
# ============================================
# 代码生成需要代码能力强的模型，建议用最好的模型。
# 如果不配置，自动回退到 EVAL_PLAN_CODING_* → LLM_*

# EVAL_CODING_PROVIDER=openai
# EVAL_CODING_BASE_URL=http://localhost:8000/v1
# EVAL_CODING_API_KEY=not-needed
# EVAL_CODING_MODEL=qwen3.6-27b
# EVAL_CODING_TEMPERATURE=0.2
# EVAL_CODING_MAX_TOKENS=4096
# EVAL_CODING_EXTRA_BODY=


# ============================================
# 5. 【新增】Unified Agent 专用配置（简单任务：单步 PlanCoding）
# ============================================
# 简单任务一步完成，不需要太强的规划能力，可以用更快的轻量模型。
# 如果不配置，自动回退到 EVAL_PLAN_CODING_* → LLM_*

# EVAL_UNIFIED_PROVIDER=openai
# EVAL_UNIFIED_BASE_URL=http://localhost:8000/v1
# EVAL_UNIFIED_API_KEY=not-needed
# EVAL_UNIFIED_MODEL=qwen2.5-7b
# EVAL_UNIFIED_TEMPERATURE=0.3
# EVAL_UNIFIED_MAX_TOKENS=4096
# EVAL_UNIFIED_EXTRA_BODY=


# ============================================
# 6. 评测系统 - Judge Agent（评估判断）
# ============================================

EVAL_JUDGE_PROVIDER=openai
EVAL_JUDGE_BASE_URL=http://localhost:8000/v1
EVAL_JUDGE_API_KEY=not-needed
EVAL_JUDGE_MODEL=qwen2.5-14b
EVAL_JUDGE_TEMPERATURE=0.1
EVAL_JUDGE_MAX_TOKENS=2048
EVAL_JUDGE_EXTRA_BODY=


# ============================================
# 7. 评测系统 - Intent Recognition Agent（意图识别）
# ============================================

EVAL_INTENT_PROVIDER=ollama
EVAL_INTENT_BASE_URL=http://localhost:8000/v1
EVAL_INTENT_API_KEY=ollama
EVAL_INTENT_MODEL=qwen2.5-7b
EVAL_INTENT_TEMPERATURE=0.2
EVAL_INTENT_MAX_TOKENS=1024
EVAL_INTENT_EXTRA_BODY=


# ============================================
# 8. 应用基础配置（可选）
# ============================================

# APP_NAME=ML Agent Backend
# DEBUG=false

# ============================================
# 9. 沙箱执行配置（可选）
# ============================================

# SANDBOX_TIMEOUT=300
# SANDBOX_MEMORY_LIMIT=2g
# SANDBOX_CPU_LIMIT=2.0

# ============================================
# 10. 快速模式限制（可选）
# ============================================

# FAST_MAX_OPTIMIZE_ROUNDS=3
# FAST_MAX_DEBUG_ROUNDS=5
# FAST_MAX_USER_FEEDBACK_ROUNDS=3
