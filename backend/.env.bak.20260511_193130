# ============================================
# ML Workflow 环境变量配置文件
# 性价比最优方案：DeepSeek + 本地 Ollama 混合部署
# ============================================


# ============================================
# 1. 全局 LLM 配置（DeepSeek）
# ============================================

# 提供商
LLM_PROVIDER=openai

# DeepSeek API 地址（OpenAI 兼容格式）
LLM_BASE_URL=https://api.siliconflow.cn/v1

# 【请填写你的 DeepSeek API Key】
LLM_API_KEY=

# 默认模型：deepseek-chat（通用对话，性价比最高）
LLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct

# 采样温度
LLM_TEMPERATURE=0.3

# 最大生成 token 数
LLM_MAX_TOKENS=4096


# ============================================
# 2. 评测系统 - PlanCoding Agent（DeepSeek）
# 核心代码生成 Agent，必须用最强模型
# ============================================

EVAL_PLAN_CODING_PROVIDER=openai
EVAL_PLAN_CODING_BASE_URL=http://localhost:8000/v1
# 【请填写你的 DeepSeek API Key】
EVAL_PLAN_CODING_API_KEY=sk-fake-key-vllm
# deepseek-chat 代码能力优秀，如需更强代码专项能力可改为 deepseek-coder
EVAL_PLAN_CODING_MODEL=qwen3.6-27b
EVAL_PLAN_CODING_TEMPERATURE=0.2
EVAL_PLAN_CODING_MAX_TOKENS=4096
# JSON 格式额外参数，DeepSeek 无需特别配置，留空即可
EVAL_PLAN_CODING_EXTRA_BODY=


# ============================================
# 3. 评测系统 - Judge Agent（本地 Ollama）
# 评估判断任务，轻量本地模型即可胜任
# ============================================

EVAL_JUDGE_PROVIDER=openai
EVAL_JUDGE_BASE_URL=http://localhost:8000/v1
# Ollama 不需要真实 API Key，但不能为空
EVAL_JUDGE_API_KEY=sk-fake-key-vllm
# 推荐使用 qwen2.5:14b，评估判断需要一定推理能力
# 如显存不足可降级为 qwen2.5:7b
EVAL_JUDGE_MODEL=qwen3.6-27b
EVAL_JUDGE_TEMPERATURE=0.1
EVAL_JUDGE_MAX_TOKENS=2048
EVAL_JUDGE_EXTRA_BODY=


# ============================================
# 4. 评测系统 - Intent Recognition Agent（本地 Ollama）
# 意图识别任务，最简单的本地模型即可
# ============================================

EVAL_INTENT_PROVIDER=ollama
EVAL_INTENT_BASE_URL=http://localhost:8000/v1
# Ollama 不需要真实 API Key，但不能为空
EVAL_INTENT_API_KEY=ollama
# 推荐使用 qwen2.5:7b，意图识别任务简单，小模型足够
# 如已加载 qwen2.5:14b，也可统一使用该模型
EVAL_INTENT_MODEL=qwen3.6-27b
EVAL_INTENT_TEMPERATURE=0.2
EVAL_INTENT_MAX_TOKENS=1024
EVAL_INTENT_EXTRA_BODY=


# ============================================
# 5. 应用基础配置（可选，一般保持默认）
# ============================================

# 应用名称
# APP_NAME=ML Agent Backend

# 调试模式
# DEBUG=false


# ============================================
# 6. 沙箱执行配置（可选）
# ============================================

# 代码执行超时时间（秒）
# SANDBOX_TIMEOUT=300

# 内存限制
# SANDBOX_MEMORY_LIMIT=2g

# CPU 核心数限制
# SANDBOX_CPU_LIMIT=2.0

# Python 解释器路径（默认使用当前环境）
# PYTHON_EXECUTABLE=python


# ============================================
# 7. 快速模式限制（可选）
# ============================================

# 最大优化轮数
# FAST_MAX_OPTIMIZE_ROUNDS=3

# 最大调试轮数
# FAST_MAX_DEBUG_ROUNDS=5

# 最大用户反馈轮数
# FAST_MAX_USER_FEEDBACK_ROUNDS=3


# ============================================
# 8. 数据切分默认配置（可选）
# ============================================

# 测试集比例
# DEFAULT_TEST_SIZE=0.2

# 随机种子
# DEFAULT_RANDOM_STATE=42
